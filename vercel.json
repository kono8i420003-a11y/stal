{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/notify-telegram",
      "destination": "/api/notify-telegram.ts"
    },
    {
      "source": "/api/admin/requests",
      "destination": "/api/admin/requests.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
